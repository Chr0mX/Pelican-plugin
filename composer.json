{
    "name": "chr0mx/valheim-mod-manager",
    "description": "Browse, install, update and manage BepInEx/Thunderstore Valheim mods directly from the Pelican Panel server view.",
    "type": "pelican-plugin",
    "license": "MIT",
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "filament/filament": "^4.0",
        "orchestra/testbench": "^9.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Chr0mX\\ValheimModManager\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Chr0mX\\ValheimModManager\\Tests\\": "tests/",
            "App\\": "tests/Stubs/App/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
